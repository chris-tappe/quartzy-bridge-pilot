{
  "manifest_version": 3,
  "name": "Quartzy Connect",
  "version": "0.3.0",
  "description": "Capture product data (JSON-LD or highlight mapping) in the side panel and build a request list.",
  "permissions": [
    "sidePanel",
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "exclude_matches": [
        "*://app.quartzy.com/*",
        "*://*.quartzy.com/*"
      ],
      "js": [
        "ExtractionService.js",
        "selectionMode.js",
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://app.quartzy.com/*"
      ],
      "js": [
        "quartzy_script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "action": {
    "default_title": "Quartzy Connect",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
