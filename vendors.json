{
  "fisher_scientific": {
    "match_patterns": [
      "*://*.fishersci.com/*"
    ],
    "pricing_api": "https://www.fishersci.com/api/pricing/v1/details",
    "catalog_regex": "products\\/[^\\/]+\\/([^?#]+)",
    "selectors": {
      "product_name": ".product-title",
      "catalog_number": [
        "[itemprop='sku']",
        ".product-catalog-number",
        ".cat-num",
        "#catalogNumber"
      ],
      "price": [
        "#totalPrice",
        ".pdp-price",
        ".full-price",
        "[id^='price_']"
      ]
    },
    "bulk_order": {
      "url": "https://www.fishersci.com/shop/quickorder",
      "input_selector": "#quickOrderTextArea"
    }
  },
  "vwr": {
    "match_patterns": [
      "*://*.vwr.com/*"
    ],
    "selectors": {
      "catalog_number": [
        ".kw-product-code"
      ],
      "price": [
        ".price"
      ]
    }
  },
  "qiagen": {
    "match_patterns": [
      "*://*.qiagen.com/*"
    ],
    "selectors": {
      "catalog_number": [
        ".article-number"
      ],
      "price": [
        ".price-value"
      ]
    }
  }
}